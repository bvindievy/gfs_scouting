  const toggleWatchlist  = id => setWatchlist(s => s.includes(id) ? s.filter(x=>x!==id) : [...s, id]);

  const filteredPlayers = useMemo(() => {
    let p = PLAYERS.filter(pl =>
      (search===""            || pl.name.toLowerCase().includes(search.toLowerCase()) || pl.club.toLowerCase().includes(search.toLowerCase())) &&
      (country==="All"        || pl.country===country) &&
      (position==="All"       || pl.position===position) &&
      (foot==="All"           || pl.foot===foot) &&
      (level==="All Levels"   || pl.level===level) &&
      pl.age    >= ageMin && pl.age    <= ageMax &&
      pl.height >= htMin  && pl.height <= htMax  &&
      (!onlyVideo    || pl.video) &&
      (!onlyGPS      || pl.gps) &&
      (!onlyVerified || pl.verified) &&
      (!onlyProspect || pl.prospect)
    );
    if (sortBy==="Name")       p = [...p].sort((a,b)=>a.name.localeCompare(b.name));
    if (sortBy==="Age")        p = [...p].sort((a,b)=>a.age-b.age);
    if (sortBy==="Height")     p = [...p].sort((a,b)=>b.height-a.height);
