/* ──────────────────────────────────────────────
   AI CHAT ASSISTANT
────────────────────────────────────────────── */
const AskGFS = ({ players, onClose }) => {
  const [messages, setMessages] = useState([
    { role:"assistant", content:"Hi! I'm your GFS AI Scout. Ask me to find players, compare stats, or get scouting insights." }
  ]);
  const [input, setInput] = useState("");
  const [loading, setLoading] = useState(false);
  const bottomRef = useRef(null);

  useEffect(() => { bottomRef.current?.scrollIntoView({ behavior:"smooth" }); }, [messages]);

  const playerContext = players.map(p =>
    `${p.name}: ${p.country}, ${p.position}, Age ${p.age}, Height ${p.height}cm, Foot: ${p.foot}, Club: ${p.club}, Level: ${p.level}, Verified: ${p.verified}, TopProspect: ${p.prospect}, HighPotential: ${p.highPotential}, Video: ${p.video}`
  ).join("\n");

  const send = async () => {
    if (!input.trim() || loading) return;
    const userMsg = { role:"user", content: input.trim() };
    const newMsgs = [...messages, userMsg];
    setMessages(newMsgs);
    setInput("");
    setLoading(true);
    try {
      const res = await fetch("https://api.anthropic.com/v1/messages", {
        method:"POST",
        headers:{ "Content-Type":"application/json" },
        body: JSON.stringify({
          model:"claude-sonnet-4-20250514", max_tokens:800,
          system:`You are an expert football scout AI assistant for Global Footprint Sports Management (GFS). You help scouts discover and analyse talent across Africa and beyond. Here is the current player database:\n\n${playerContext}\n\nAnswer concisely and professionally. Use emojis sparingly. When suggesting players, list their key attributes.`,
          messages: newMsgs
        })
      });
      const data = await res.json();
      const reply = data.content?.map(b => b.text||"").join("") || "Sorry, I couldn't process that.";
      setMessages(m => [...m, { role:"assistant", content:reply }]);
    } catch {
      setMessages(m => [...m, { role:"assistant", content:"Network error. Please try again." }]);
    }
    setLoading(false);
  };

  const suggestions = [
    "Show me top U20 wingers in Ghana",
    "Compare left-footed strikers",
    "Find verified players with video",
    "Who are the highest potential Academy players?"
  ];

  return (
    <div style={{
      position:"fixed", bottom:24, right:24, width:380, height:520,
      background:"#0F1C2A", border:"1px solid #1E6B5E", borderRadius:16,
      boxShadow:"0 20px 60px rgba(0,0,0,0.7)", display:"flex", flexDirection:"column", zIndex:900
    }}>
      {/* Header */}
      <div style={{
        padding:"14px 16px", borderBottom:"1px solid #1A2C3D",
        display:"flex", alignItems:"center", gap:10, justifyContent:"space-between"
      }}>
        <div style={{ display:"flex", alignItems:"center", gap:10 }}>
          <div style={{ width:36, height:36, borderRadius:10, background:"linear-gradient(135deg,#1E6B5E,#4ECDC4)", display:"flex", alignItems:"center", justifyContent:"center", fontSize:18 }}>🤖</div>
          <div>
            <div style={{ fontWeight:700, color:"#E8F0F5", fontSize:14 }}>Ask GFS AI</div>
            <div style={{ fontSize:11, color:"#4ECDC4" }}>● Online</div>
          </div>
        </div>
        <button onClick={onClose} style={{ background:"none", border:"none", color:"#5A7A90", cursor:"pointer", fontSize:18 }}>✕</button>
      </div>
      {/* Messages */}
      <div style={{ flex:1, overflowY:"auto", padding:14, display:"flex", flexDirection:"column", gap:10 }}>
        {messages.map((m,i) => (
          <div key={i} style={{
            alignSelf: m.role==="user" ? "flex-end" : "flex-start",
            maxWidth:"85%",
            background: m.role==="user" ? "linear-gradient(135deg,#1E6B5E,#2B8C6E)" : "#132030",
            border: m.role==="assistant" ? "1px solid #1A2C3D" : "none",
            borderRadius: m.role==="user" ? "12px 12px 2px 12px" : "12px 12px 12px 2px",
            padding:"10px 13px", fontSize:13, color:"#D0E4F0", lineHeight:1.5
          }}>{m.content}</div>
        ))}
        {loading && (
          <div style={{ alignSelf:"flex-start", background:"#132030", border:"1px solid #1A2C3D", borderRadius:"12px 12px 12px 2px", padding:"10px 13px" }}>
            <span style={{ color:"#4ECDC4" }}>●</span>
            <span style={{ color:"#8FA8C0", fontSize:13 }}> Analysing...</span>
          </div>
        )}
        <div ref={bottomRef}/>
      </div>
      {/* Suggestions */}
      {messages.length <= 1 && (
        <div style={{ padding:"0 14px 8px", display:"flex", flexDirection:"column", gap:5 }}>
          {suggestions.map(s => (
            <button key={s} onClick={() => setInput(s)} style={{
              background:"#132030", border:"1px solid #1A2C3D", borderRadius:8,
              padding:"7px 11px", color:"#7A9BB5", fontSize:12, cursor:"pointer",
              textAlign:"left", transition:"all 0.15s"
            }}>{s}</button>
          ))}
        </div>
      )}
      {/* Input */}
      <div style={{ padding:"10px 14px", borderTop:"1px solid #1A2C3D", display:"flex", gap:8 }}>
        <input value={input} onChange={e => setInput(e.target.value)}
          onKeyDown={e => e.key==="Enter" && send()}
          placeholder="Ask about players..." style={{
            flex:1, background:"#132030", border:"1px solid #1A2C3D", borderRadius:8,
            padding:"9px 12px", color:"#E8F0F5", fontSize:13, outline:"none", fontFamily:"inherit"
          }}/>
        <button onClick={send} disabled={loading} style={{
          background:"linear-gradient(135deg,#1E6B5E,#4ECDC4)", border:"none", borderRadius:8,
          padding:"9px 14px", color:"#fff", fontWeight:700, cursor:"pointer", fontSize:14
        }}>➤</button>
      </div>
    </div>
  );
};

