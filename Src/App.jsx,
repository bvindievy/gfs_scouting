              <span style={{ fontWeight:700, fontSize:14, color:"#B8D0E0" }}>Filters</span>
              <button onClick={() => { setCountry("All"); setPosition("All"); setFoot("All"); setLevel("All Levels"); setAgeMin(16); setAgeMax(35); setHtMin(160); setHtMax(200); setOnlyVideo(false); setOnlyGPS(false); setOnlyVerified(false); setOnlyProspect(false); }}
                style={{ background:"none", border:"none", color:"#4ECDC4", cursor:"pointer", fontSize:12 }}>Reset</button>
            </div>

            <div style={sectionStyle}>
              <label style={labelStyle}>Country</label>
              {sel(country, setCountry, COUNTRIES)}
            </div>
            <div style={sectionStyle}>
              <label style={labelStyle}>Age Range: {ageMin} – {ageMax}</label>
              {inp(ageMin, setAgeMin, 14, ageMax)} {inp(ageMax, setAgeMax, ageMin, 40)}
            </div>
            <div style={sectionStyle}>
              <label style={labelStyle}>Position</label>
              {sel(position, setPosition, POSITIONS)}
            </div>
            <div style={sectionStyle}>
              <label style={labelStyle}>Preferred Foot</label>
              {sel(foot, setFoot, FEET)}
            </div>
            <div style={sectionStyle}>
              <label style={labelStyle}>Height: {htMin} – {htMax}cm</label>
              {inp(htMin, setHtMin, 155, htMax)} {inp(htMax, setHtMax, htMin, 210)}
            </div>
            <div style={sectionStyle}>
              <label style={labelStyle}>Level</label>
              {sel(level, setLevel, LEVELS)}
            </div>
            <div style={{ borderTop:"1px solid #1A2C3D", paddingTop:14, marginBottom:14 }}>
              {[
                [onlyVideo,    setOnlyVideo,    "🎥 Video Available"],
                [onlyGPS,      setOnlyGPS,      "📡 GPS Data"],
                [onlyVerified, setOnlyVerified, "✅ Verified"],
                [onlyProspect, setOnlyProspect, "⭐ Top Prospect"],
              ].map(([val,setter,label]) => (
                <label key={label} style={{ display:"flex", alignItems:"center", gap:8, marginBottom:10, cursor:"pointer", fontSize:12, color:"#7A9BB5" }}>
                  <input type="checkbox" checked={val} onChange={e=>setter(e.target.checked)}
                    style={{ accentColor:"#4ECDC4", width:14, height:14 }}/>
                  {label}
                </label>
              ))}
            </div>
            <button style={{
              width:"100%", background:"linear-gradient(135deg,#1E6B5E,#4ECDC4)",
              border:"none", borderRadius:10, padding:"11px 0", color:"#fff",
              fontWeight:700, cursor:"pointer", fontSize:13, marginBottom:8
            }}>Apply Filters ({filteredPlayers.length})</button>
          </div>
        )}
      </div>

      {/* ── MODALS ── */}
      {selectedPlayer && (
        <PlayerModal player={selectedPlayer} onClose={() => setSelectedPlayer(null)}
          isShortlisted={shortlist.includes(selectedPlayer.id)}
          isWatchlisted={watchlist.includes(selectedPlayer.id)}
          onShortlist={id => { toggleShortlist(id); }}
          onWatchlist={id => { toggleWatchlist(id); }}/>
      )}
      {showAI && <AskGFS players={PLAYERS} onClose={() => setShowAI(false)}/>}

      {/* Google Fonts */}
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800;900&family=Outfit:wght@400;500;600;700;800&display=swap');
        * { box-sizing: border-box; margin: 0; padding: 0; }
        ::-webkit-scrollbar { width: 5px; }
        ::-webkit-scrollbar-track { background: #091420; }
        ::-webkit-scrollbar-thumb { background: #1A2C3D; border-radius: 4px; }
        input[type=range] { -webkit-appearance: none; height: 4px; border-radius: 4px; background: #1A2C3D; }
        input[type=range]::-webkit-slider-thumb { -webkit-appearance: none; width: 14px; height: 14px; background: #4ECDC4; border-radius: 50%; cursor: pointer; }
        select option { background: #132030; color: #B8D0E0; }
      `}</style>
    </div>
  );
}
